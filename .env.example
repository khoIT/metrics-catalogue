# =============================================================================
# Cube API
# =============================================================================
CUBEJS_DEV_MODE=true
CUBEJS_API_SECRET=local-dev-secret-change-me-in-prod-please-32chars
CUBEJS_LOG_LEVEL=info
CUBEJS_SCHEMA_PATH=model

# =============================================================================
# Trino connection
# Cube uses the prestodb/trino driver. Set CUBEJS_DB_TYPE=trino.
# =============================================================================
CUBEJS_DB_TYPE=trino
CUBEJS_DB_HOST=your.trino.host.example.com
CUBEJS_DB_PORT=8080
CUBEJS_DB_USER=trino_user
CUBEJS_DB_PASS=
CUBEJS_DB_PRESTO_CATALOG=game_integration
CUBEJS_DB_SCHEMA=ballistar_vn
CUBEJS_DB_SSL=false

# =============================================================================
# SQL API (Postgres wire protocol) — lets BI tools / LLM clients connect
# as if Cube were a Postgres database.
# =============================================================================
CUBEJS_PG_SQL_PORT=15432
CUBEJS_SQL_USER=cube
CUBEJS_SQL_PASSWORD=cube

# =============================================================================
# Cube Store (pre-aggregation storage). The compose file wires this for you.
# Port 3030 is the HTTP/RPC orchestration port cubestored serves (visible in
# `docker logs ballistar_cubestore`: "Http Server is listening on 0.0.0.0:3030").
# The legacy default `9999` is NOT used by cubestored v1.6+ in standalone mode
# and causes Cube's scheduler to hang on "Continue wait" forever.
# =============================================================================
CUBEJS_CUBESTORE_HOST=cubestore
CUBEJS_CUBESTORE_PORT=3030

# =============================================================================
# Refresh worker — keep disabled for POC. The scheduled-refresh worker has
# nothing useful to do until pre-aggregations are defined in the YAML schema;
# in-process it spin-loops polling partition refresh keys and pegs the event
# loop at ~100% CPU, which starves the HTTP server (readyz / meta time out).
# Re-enable when pre-aggregations are added to the schema.
# =============================================================================
CUBEJS_REFRESH_WORKER=false

# =============================================================================
# Per-host architecture override for the CubeStore image tag.
# `cubejs/cubestore:latest` is NOT a multi-arch manifest — Cube ships separate
# tags per arch. The compose file defaults to the amd64 tag (`v1.6.46`).
# Uncomment ONLY if your host is arm64.
#   Apple Silicon (M-series):   CUBESTORE_TAG=v1.6.46-arm64v8
#   x86-64 (Win / Linux / Intel Mac): leave commented out — default works
# Running the amd64 tag on arm64 under Colima/Docker-Desktop emulation wedges
# the Rust binary silently (no logs, no listening ports).
# =============================================================================
# CUBESTORE_TAG=v1.6.46-arm64v8

# =============================================================================
# Optional: tune Trino driver
# =============================================================================
# CUBEJS_DB_MAX_POOL=20
# CUBEJS_CONCURRENCY=10

# Set to 0 if your Trino role lacks SET_SYSTEM_SESSION_PROPERTY privilege
# for query_max_run_time. Cube then stops sending the SET SESSION prepend
# and relies on Trino's server-side timeout. Default is 10m when unset.
# CUBEJS_DB_QUERY_TIMEOUT=0
